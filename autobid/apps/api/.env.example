# ---- Supabase / Postgres ----
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Government APIs ----
# Rotate the key that was shared in chat, then paste the NEW one here only.
SAM_GOV_API_KEY=
# grants.gov search2 + usaspending require no key

# ---- AI ----
ANTHROPIC_API_KEY=
OPENAI_API_KEY=            # used for embeddings (text-embedding-3-small, 1536-dim)
MODEL_CRITICAL=claude-opus-4-7
MODEL_DRAFT=claude-sonnet-4-6
EMBED_MODEL=text-embedding-3-small
EMBED_DIM=1536

# ---- Queue ----
REDIS_URL=redis://localhost:6379/0

# ---- Email (Phase 6+) ----
RESEND_API_KEY=
NOTIFY_FROM=AutoBid <alerts@yourdomain.com>
INBOUND_PARSE_SECRET=

# ---- App ----
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
